# ---------------------------------------------------------------------------
# Frontend environment (Next.js). Copy to `.env.local` and fill in real values.
# Only NEXT_PUBLIC_* vars are exposed to the browser.
# ---------------------------------------------------------------------------

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous (publishable) key. Safe for the browser; protected by RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Base URL of the FastAPI backend. Defaults to http://localhost:8000 if unset.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Show the "Email PDF" report button. Requires a verified Resend sending domain,
# so it's off by default (public free deploy can't send to arbitrary users).
# "Download PDF" always works. Set to "true" only once a domain is configured.
NEXT_PUBLIC_ENABLE_EMAIL=false
