# ---------------------------------------------------------------------------
# Backend environment (FastAPI). Copy to `backend/.env` and fill in real keys.
# All are optional individually, but valuation/AI features degrade without them.
# ---------------------------------------------------------------------------

# Financial Modeling Prep — PRIMARY data source for the full valuation engine
# (price, statements, DCF). 250 requests/day PER KEY on the free tier.
# Add extra free keys (separate accounts) to multiply the daily budget — the
# backend rotates through them, draining one before moving to the next
# (2 keys = 500/day, 3 keys = 750/day). https://financialmodelingprep.com
FMP_API_KEY=
FMP_API_KEY_2=
FMP_API_KEY_3=

# Finnhub — free, uncapped (60 req/min) market data: price, current multiples,
# sector, and a historical-growth PROXY used for the DCF when no forward estimate
# is available. Part of the always-on EDGAR+Finnhub backup. https://finnhub.io
FINNHUB_API_KEY=

# BusinessQuant — the only FREE source of analyst FORWARD estimates (forward
# revenue/EPS consensus), the one input EDGAR/Finnhub can't supply. Free tier is
# 30 requests/day PER KEY, so add several free-account keys and the backend rotates
# through them (6 keys = 180/day ≈ 90 stocks/day with real estimates). When all keys
# are spent the DCF falls back to the Finnhub historical-growth proxy — valuations
# never break, just get slightly less precise until the cap resets. https://businessquant.com
BUSINESSQUANT_API_KEY=
BUSINESSQUANT_API_KEY_2=
BUSINESSQUANT_API_KEY_3=
BUSINESSQUANT_API_KEY_4=
BUSINESSQUANT_API_KEY_5=
BUSINESSQUANT_API_KEY_6=

# LLM providers (used as a fallback chain: Groq -> Gemini -> Cerebras).
GROQ_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=

# Resend — transactional email for PDF report delivery. https://resend.com
RESEND_API_KEY=

# Comma-separated browser origins allowed by CORS. Defaults to http://localhost:3000.
# In production set this to the deployed frontend URL, e.g.
# CORS_ALLOWED_ORIGINS=https://moat-yourname.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000
