# ---------------------------------------------------------------------------
# Backend environment (FastAPI). Copy to `backend/.env` and fill in real keys.
# All are optional individually, but valuation/AI features degrade without them.
# ---------------------------------------------------------------------------

# Financial Modeling Prep — external DCF + fundamentals. https://financialmodelingprep.com
FMP_API_KEY=

# LLM providers (used as a fallback chain: Groq -> Gemini -> Cerebras).
GROQ_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=

# Resend — transactional email for PDF report delivery. https://resend.com
RESEND_API_KEY=
