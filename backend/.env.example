# ---------------------------------------------------------------------------
# Backend environment (FastAPI). Copy to `backend/.env` and fill in real keys.
# All are optional individually, but valuation/AI features degrade without them.
# ---------------------------------------------------------------------------

# Financial Modeling Prep — PRIMARY data source for the full valuation engine
# (price, statements, DCF). 250 requests/day PER KEY on the free tier.
# Add extra free keys (separate accounts) to multiply the daily budget — the
# backend rotates through them, draining one before moving to the next
# (2 keys = 500/day, 3 keys = 750/day). https://financialmodelingprep.com
FMP_API_KEY=
FMP_API_KEY_2=
FMP_API_KEY_3=

# Finnhub — third-tier resilience provider (60 req/min free). Used only when both
# yfinance and FMP are unavailable. Optional; degrades gracefully if unset. https://finnhub.io
FINNHUB_API_KEY=

# LLM providers (used as a fallback chain: Groq -> Gemini -> Cerebras).
GROQ_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=

# Resend — transactional email for PDF report delivery. https://resend.com
RESEND_API_KEY=

# Comma-separated browser origins allowed by CORS. Defaults to http://localhost:3000.
# In production set this to the deployed frontend URL, e.g.
# CORS_ALLOWED_ORIGINS=https://moat-yourname.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000
